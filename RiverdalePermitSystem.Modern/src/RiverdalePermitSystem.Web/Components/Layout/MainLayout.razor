@inherits LayoutComponentBase

<div class="page">
    <header class="header">
        <h1>Riverdale City Council — Building Permit System</h1>
        <div class="user-info">
            <UserInfo />
        </div>
    </header>

    <nav class="navigation">
        <NavMenu />
    </nav>

    <main class="content">
        <ErrorBoundary @ref="_errorBoundary">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <div class="alert alert-danger">
                    <h4>An error occurred</h4>
                    <p>We're sorry, something went wrong. Please try again.</p>
                    <button class="btn btn-primary" @onclick="() => _errorBoundary?.Recover()">Try Again</button>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </main>

    <footer class="footer">
        <p>&copy; @DateTime.Now.Year Riverdale City Council. All rights reserved. | Contact: permits@riverdalecity.gov | Phone: (555) 123-4567</p>
    </footer>
</div>

@code {
    private ErrorBoundary? _errorBoundary;
}
